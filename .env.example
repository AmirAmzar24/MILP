# ============================================
# Environment Configuration Template
# ============================================
# install.ps1 copies this file to .env automatically. The defaults below are
# tuned for LOCAL development so the app runs out of the box on one machine.
#
# >>> BEFORE ANY REAL/SHARED DEPLOYMENT, change the values marked [CHANGE FOR PROD]. <<<
# IMPORTANT: Never commit .env to version control!
# ============================================

# Flask Configuration
# 'development' for local use; set 'production' when deploying.  [CHANGE FOR PROD]
FLASK_ENV=development
# SECURITY: MUST be False in production to prevent code exposure.
# Debug is also auto-disabled when FLASK_HOST is not loopback (the Werkzeug
# debugger would otherwise allow remote code execution).
FLASK_DEBUG=False
FLASK_PORT=5000
# Bind host. 127.0.0.1 = localhost only (default, safest). Set 0.0.0.0 to allow
# LAN access; debug is then forced off automatically.
FLASK_HOST=127.0.0.1

# Gurobi License Configuration
# Choose one of the following options:

# Option 1: Local license file path
# GRB_LICENSE_FILE=C:\path\to\gurobi.lic

# Option 2: Gurobi Cloud/WLS credentials
# GRB_WLSACCESSID=your_access_id
# GRB_WLSSECRET=your_secret
# GRB_LICENSEID=your_license_id

# CORS Settings
# Which browser origins may call the API. The default below matches the local
# Vite dev server (http://localhost:5173). If you change the frontend port or
# deploy, update this.  [CHANGE FOR PROD: set to your real frontend URL(s)]
# Multiple origins can be comma-separated: https://app.example.com,https://www.example.com
# DO NOT use '*' in production! Note: both ALLOWED_ORIGINS and CORS_ORIGINS work.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Authentication
# ---------------------------------------------------------------------------
# A working DEV login is pre-configured so you can sign in immediately:
#       username: admin@example.com
#       password: admin
# [CHANGE FOR PROD] These are known, weak credentials. Before sharing the app:
#   1. New secret:    python -c "import secrets; print(secrets.token_urlsafe(48))"
#   2. New password:  python APIs/hash_password.py 'your-new-password'
#   ...then paste the results into JWT_SECRET and AUTH_PASSWORD_HASH below.
# ---------------------------------------------------------------------------
JWT_SECRET=bGSj87XDvreG7aZRnbyysr1BUvF3BvAVZic40Tym0btiwTR2rHiFI2L_UM_3weOS
AUTH_USERNAME=admin@example.com
# Hash of the password "admin" (generated with APIs/hash_password.py).
AUTH_PASSWORD_HASH=scrypt:32768:8:1$aUw7730qxoxaKXC6$64e211b203bbd54bb57c440aedfaecde078fc7fd607c02e9aeeb07dad6b6efbb1175a2d667728edb05e67f95b42089e4f83374beefd0e3949d0b51ff752efc5a
# Multi-user alternative (JSON map; overrides AUTH_USERNAME/AUTH_PASSWORD_HASH):
# AUTH_USERS={"alice@example.com":"<hash>","bob@example.com":"<hash>"}

# Rate limiting
# Optional shared storage for multi-process/production deploys (e.g. redis://localhost:6379)
# Defaults to in-memory (per-process) when unset.
# RATELIMIT_STORAGE_URI=redis://localhost:6379

# Reverse proxy
# SECURITY: set to 'true' ONLY when running behind a trusted reverse proxy that
# sets X-Forwarded-For (e.g. nginx/Caddy for TLS). This makes rate limiting and
# logging use the real client IP. Leave 'false' otherwise - enabling it without
# a proxy lets clients spoof their IP and bypass rate limits.
TRUST_PROXY=false

# MongoDB Connection (OPTIONAL — the optimizer runs fine without it)
# Only needed to store/browse timing-plan history. Leave unset to disable.
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/advancti?retryWrites=true&w=majority
